@model List<Task01.Models.Employee>
@{
    ViewData["Title"] = "Display Employees";
}

<h2>Employees List (Real-time)</h2>

<table class="table table-bordered" id="employeesTable">
    <thead>
        <tr>
            <th>Name</th>
            <th>Address</th>
            <th>Age</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var emp in Model)
        {
            <tr>
                <td>@emp.Name</td>
                <td>@emp.Address</td>
                <td>@emp.Age</td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
    <script>
        var connection = new signalR.HubConnectionBuilder()
            .withUrl("/employeeHub")
            .build();

        connection.on("ReceiveNewEmployee", function (name, address, age) {
            var newRow = `<tr>
                            <td>${name}</td>
                            <td>${address}</td>
                            <td>${age}</td>
                          </tr>`;
            document.querySelector("#employeesTable tbody").innerHTML += newRow;
        });

        connection.start().then(function () {
            console.log("Connected to SignalR Hub!");
        }).catch(function (err) {
            return console.error(err.toString());
        });
    </script>
}
