@{
    ViewData["Title"] = "Display Employees";
}

<h2>Employees List (Real-time)</h2>

<table class="table table-bordered" id="employeesTable">
    <thead>
        <tr>
            <th>Name</th>
            <th>Address</th>
            <th>Age</th>
        </tr>
    </thead>
    <tbody>
    </tbody>
</table>

@section Scripts {
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
    <script>
        // 1. Set up the connection to the Hub (same path we wrote in Program.cs)
        var connection = new signalR.HubConnectionBuilder()
            .withUrl("/employeeHub")
            .build();

        // 2. Receiving data from the server
        // "ReceiveNewEmployee" must be the same name we entered in the Controller
        connection.on("ReceiveNewEmployee", function (name, address, age) {
            // build a new row with the received employee data
            var newRow = `<tr>
                            <td>${name}</td>
                            <td>${address}</td>
                            <td>${age}</td>
                          </tr>`;
        
            // add the new row to the table body
            document.querySelector("#employeesTable tbody").innerHTML += newRow;
        });

        // start the connection
        connection.start().then(function () {
            console.log("Connected to SignalR Hub!");
        }).catch(function (err) {
            return console.error(err.toString());
        });
    </script>
}